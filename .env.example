# Azure DevOps
AZURE_DEVOPS_COLLECTION_URL=COLLECTION_BASE_URL_HERE
AZURE_DEVOPS_PROJECT=PROJECT_NAME_HERE
AZURE_DEVOPS_PAT=PASTE_YOUR_PAT_HERE

# Use npm run fields to verify this reference name.
EXPECTED_FINISH_FIELD=Custom.ExpectedFinishDate

# Optional: include only these work item types. Comma separated.
WORK_ITEM_TYPES=User Story,Bug,Task

# Bot Framework / Teams App
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=

# Server
PORT=3978

# Daily post schedule - India time. 17:30 means 5:30 PM.
DAILY_CRON=30 17 * * 1-5
TZ=Asia/Kolkata

# Optional fallback channel. Use "subscribe" command in Teams first.
CONVERSATION_STORE_PATH=.data/conversation-reference.json

# POD filter
POD_FILTER_ENABLED=true
POD_FIELD=System.AreaPath
POD_VALUE=POD_NAME_HERE
POD_MATCH_MODE=contains

# Sprint filter
TARGET_SPRINT_FIELD=Custom.TargetSprint
TARGET_SPRINT_VALUE=January H2